{"legislative_session": "20252026", "identifier": "SJR13", "title": "Transboundary flow pollution: United States-Mexico-Canada Agreement.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["joint resolution"], "subject": ["Transboundaryflowpollution", "UnitedStates-Mexico-CanadaAgreement"], "abstracts": [{"note": "summary", "abstract": "This measure would request the United States, at the 2026 joint review of the United States-Mexico-Canada Agreement (USMCA) , to secure and publicly adopt measurable and sustained commitments from the parties to eliminate chronic transboundary sewage discharges into the Tijuana River watershed and the flow of untreated sewage, industrial effluent, and toxic pollutants through the New River from Mexicali into the County of Imperial. The measure would further request that the United States commit to automatic nonrenewal of the USMCA should there be a failure of establishing commitments, benchmarks, and timelines relating to specific numeric discharge-reduction benchmarks for both the Tijuana River watershed and the New River, investment into and enforceable timelines for completion of wastewater infrastructure projects, and annual public reporting on compliance."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sjr13"}], "actions": [{"description": "Introduced. Referred to Com. on RLS.", "date": "2026-03-24", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}, {"description": "Re-referred to Com. on E.Q.", "date": "2026-04-08", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on E.Q.", "entity_type": "organization", "organization_id": null}]}, {"description": "Set for hearing April 22.", "date": "2026-04-17", "organization_id": "~{