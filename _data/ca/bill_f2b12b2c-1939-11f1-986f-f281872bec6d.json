{"legislative_session": "20252026", "identifier": "SB1319", "title": "Fairs: state funding: classification.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Fairs", "classification", "statefunding"], "abstracts": [{"note": "summary", "abstract": "Existing law governs the apportionment of state funds to fairs within the network of California fairs, which includes, in general, the California Exposition and State Fair, district agricultural association fairs, county fairs, and citrus fruit fairs. Existing law authorizes the Department of Food and Agriculture to classify fairs and requires the department to consider whether to classify or reclassify fairs at least once every 5 years, as specified.\n\nThis bill would make a nonsubstantive change to that provision."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Gonzalez", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Gonzalez\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "SB1319", "links": [{"url": "http://leginfo.legisl