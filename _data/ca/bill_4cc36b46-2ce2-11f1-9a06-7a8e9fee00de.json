{"legislative_session": "20252026", "identifier": "AB2246", "title": "Youth Social Media Protection Act: report.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["YouthSocialMediaProtectionAct", "report"], "abstracts": [{"note": "summary", "abstract": "The Youth Social Media Protection Act requires a large social media platform to create a process by which a verified reporter can make a report of a social media-related threat or a violation of the large social media platform's terms of service that in the verified reporter's opinion poses a risk or a severe risk to the health and safety of a minor, as specified.\n\nThis bill would require the Attorney General to submit a report to the Legislature on children's safety features on social media platforms."}], "other_titles": [{"note": "", "title": "Cannabis."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2246"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Coms. on P. & C.P. and JUD.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Coms. on P. & C.P. and JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on P. & C.P. Read second time and amended.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred to Com. on P.