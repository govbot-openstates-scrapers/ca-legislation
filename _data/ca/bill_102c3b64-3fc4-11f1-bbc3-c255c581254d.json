{"legislative_session": "20252026", "identifier": "SB1361", "title": "Transit-oriented housing developments: local governments: transit providers and projects.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Transit-orientedhousingdevelopments", "localgovernments", "transitprovidersandprojects"], "abstracts": [{"note": "summary", "abstract": "Existing law requires a housing development project to be an allowed use as a transit-oriented housing development if certain requirements are met. Existing law provides that these provisions do not apply to a local agency until July 1, 2026, unless the local agency takes specified actions. Existing law defines various terms for these purposes. Existing law prohibits a local government from adopting any requirement that applies to a project solely or partially on the basis that the project is seeking approval as a transit-oriented housing development, as specified.\n\nThis bill would additionally prohibit a local government with an existing or planned transit-oriented development stop from taking specified actions with respect to transit providers and transit projects."}], "other_titles": [{"note": "", "title": "Transit-oriented housing developments: exceptions: housing development policy."}, {"note": "", "title": "Community facilities districts."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1361"}], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "r