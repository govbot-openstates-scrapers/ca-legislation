{"legislative_session": "20252026", "identifier": "SB1148", "title": "Security guards: training.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Securityguards", "training"], "abstracts": [{"note": "summary", "abstract": "Existing law, the Private Security Services Act, provides for the licensure and regulation of, among others, security guards by the Bureau of Security and Investigative Services. Existing law requires a security guard registrant to complete not less than 32 hours of training in security officer skills within 6 months from the date an initial registration is issued and requires a security guard registrant to complete 16 of the 32 hours within 30 days from the date the registration is issued, except as specified.\n\nThis bill would also authorize a security guard registrant to complete those required hours of training before the date the registration is issued."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1148"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 21.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on B. P. & E.D.", "date": "2026-02-26", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on B. P. & E.D.", "entity_type": "organization", "organization_id": null}]}, {"description": "Set for hearing March 23.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "From committee: Do pass and re-refer to Com. on APPR. with recommendation: To consent calendar. (Ayes 9. Noes 0.) (March 23). Re-referred to Com. on APPR.", "date": "2026-03-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["committee-passage", "committee-passage-favorable", "referral-committee"], "related_entities": [{"name": "Com. on APPR.", "entity_type": "organization", "organization_id": null}]}, {"description": "Set for hearing April 13.", "date": "2026-03-27", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}], "sponsorships": [{"name": "Niello", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Niello\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "SB1148", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260SB1148", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "02/18/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260SB1148&version=20250SB114899INT", "media_type": "application/pdf"}], "date": "2026-02-18", "classification": ""}], "documents": [{"note": "03/20/26- Senate Business, Professions and Economic Development", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billAnalysisClient.xhtml?bill_id=202520260SB1148&analysisId=394457&analyzingOffice=Senate+Business,+Professions+and+Economic+Development", "media_type": "application/pdf"}], "date": "2026-03-20", "classification": "analysis"}], "citations": [], "sources": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260SB1148", "note": ""}], "extras": {"impact_clause": "An act to amend Section 7583.6 of the Business and Professions Code, relating to professions and vocations.", "tags": ["fiscal committee"]}, "jurisdiction": {"id": "ocd-jurisdiction/country:us/state:ca/government", "name": "California", "classification": "stat