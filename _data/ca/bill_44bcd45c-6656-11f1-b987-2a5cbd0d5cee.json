{"legislative_session": "20252026", "identifier": "AB817", "title": "Courts: electronic records.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Courts", "electronicrecords"], "abstracts": [{"note": "summary", "abstract": "Existing law requires a clerk of the superior court to keep an index of any action or proceeding filed in the court. Existing law requires a separate index for plaintiffs and defendants in civil actions and for defendants in criminal actions.\n\nThis bill would require publicly accessible electronic indices of criminal cases to allow searches based on an individual's driver's license, date of birth, or name. The bill would require the court index to only return records that match the identifiers entered, and would require that those results be redacted, as specified."}], "other_titles": [{"note": "", "title": "Gambling Control Act."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab817"}], "actions": [{"description": "Read first time. To print.", "date": "2025-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 22.", "date": "2025-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on G.O.", "date": "2025-03-03", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on G.O.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass and re-refer to Com. on APPR. with recommendation: To Consent Calendar. (Ayes 21. Noes 0.) (April 2). Re-referred to Com. on APPR.", "date": "2025-04-03", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage", "committee-passage-favorable", "referral-committee"], "related_enti