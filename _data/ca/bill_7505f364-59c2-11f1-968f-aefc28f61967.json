{"legislative_session": "20252026", "identifier": "AB2294", "title": "State holidays: Sylvia Mendez Day.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Stateholidays", "SylviaMendezDay"], "abstracts": [{"note": "summary", "abstract": "Existing law designates specific days as holidays in this state, including, among others, Dr. Martin Luther King, Jr. Day and Cesar Chavez Day. Existing law designates certain days as judicial holidays and exempts others including, Lunar New Year, Diwali, and Genocide Remembrance Day.\n\nThis bill would designate Sylvia Mendez Day as a state holiday, but would exempt the holiday from being a judicial holiday. The bill would include related legislative findings and declarations."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2294"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on G.O.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on G.O.", "entity_type": "organization", "organization_id": null}]}, {"description": "In committee: Set, first hearing. Hearing canceled at the request of author.", "date": "2026-04-08", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on G.O. Read second time and amended.", "date": "2026-04-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amend