{"legislative_session": "20252026", "identifier": "AB2472", "title": "Emergency services: catastrophic plans.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Emergencyservices", "catastrophicplans"], "abstracts": [{"note": "summary", "abstract": "Existing law, the California Emergency Services Act, establishes the Office of Emergency Services (OES) within the office of the Governor, and sets forth its powers and duties, including responsibility for addressing natural, technological, or manmade disasters and emergencies, including activities necessary to prevent, respond to, recover from, and mitigate the effects of emergencies and disasters to people and property.\n\nThis bill would require OES, in consultation with relevant state and local agencies, to develop catastrophic plans, as described."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on E.M.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on E.M.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on E.M. Read second time and amended.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred to Com. on E.M.", "date": "2026-03-10", "organization_id": "~{\"classification\": 