{"legislative_session": "20252026", "identifier": "SB1366", "title": "Public Utilities Commission: report.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["PublicUtilitiesCommission", "report"], "abstracts": [{"note": "summary", "abstract": "Existing law vests the Public Utilities Commission with regulatory authority over public utilities, including every common carrier, toll bridge corporation, pipeline corporation, gas corporation, electrical corporation, telephone corporation, telegraph corporation, water corporation, sewer system corporation, and heat corporation, as specified. Existing law requires each state agency, including the commission, to provide the Director of General Services with an annual report on late payment penalties that were paid by the agency, as provided.\n\nThis bill would require the commission to annually submit a report to the Legislature with information related to the payment of invoices, as provided."}], "other_titles": [{"note": "", "title": "State government: California Prompt Payment Act: Public Utilities Commission: State Energy Resources Conservation and Development Commission."}, {"note": "", "title": "California Prompt Payment Act."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1366"}], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-03-04", "organization_id": "~{\"class