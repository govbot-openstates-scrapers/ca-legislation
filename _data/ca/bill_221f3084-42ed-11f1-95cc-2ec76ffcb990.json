{"legislative_session": "20252026", "identifier": "AB2760", "title": "County board of supervisors: inspector general.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Countyboardofsupervisors", "inspectorgeneral"], "abstracts": [{"note": "summary", "abstract": "Existing law requires a board of supervisors to supervise the official conduct of all county officers and ensure that they faithfully perform their duties. Existing law authorizes a county, either by action of the board of supervisors or through a vote of county residents, to establish an office of the inspector general to assist the board of supervisors with these duties as they relate to the sheriff.\n\nThis bill would authorize a county, either by action of the board of supervisors or through a vote of county residents, to establish an office of the inspector general to assist the board of supervisors with these duties as they relate to the county animal control department or the office of chief probation, as defined."}], "other_titles": [{"note": "", "title": "Educational equity: discrimination: Office of Civil Rights."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2760"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on PUB. S.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on PUB. S.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on PUB. S. Read second ti