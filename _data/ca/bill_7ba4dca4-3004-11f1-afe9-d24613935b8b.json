{"legislative_session": "20252026", "identifier": "SB1150", "title": "Cancer data: notifications.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Cancerdata", "notifications"], "abstracts": [{"note": "summary", "abstract": "Existing law requires the State Department of Public Health to conduct a program of epidemiological assessments of the incidence of cancer. Existing law requires specified entities providing specified services to cancer patients, including hospitals, practitioners, and laboratories, to report each case of cancer to the department, as specified.\n\nThis bill would require an entity described above to, within 5 business days of making a report to the department, notify the patient by mail that the entity has reported the patient's case to the department as described above and that the department may use that report to add the patient's case to a registry of cancer cases."}], "other_titles": [{"note": "", "title": "Cancer data."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1150"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 21.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-02-26", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee with author's amendments. Read second time and amended. Re-referred to Com. on RLS.", "date": "2026-03-25", "organization_id": "~{\"classification\": \"upper\"}", "c