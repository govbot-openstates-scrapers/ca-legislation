{"legislative_session": "20252026", "identifier": "SB1382", "title": "Department of Transportation: mountain passes: openings.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["DepartmentofTransportation", "mountainpasses", "openings"], "abstracts": [{"note": "summary", "abstract": "Existing law vests the Department of Transportation with possession and control of all state highways. Existing law requires the department, on or before July 1, 1992, to adopt and implement a deicing policy for state highways, as specified. Existing law specifically requires the department to remove snow from a specified portion of Interstate Route 80, as specified.\n\nThis bill would require, on or before April 1 of each year, the department, to the extent feasible, to notify an affected local official of the department's proposed schedule for opening a mountain pass, as defined. The bill would require the department to develop a public outreach plan to inform the public about the closing and opening of a mountain pass, as specified."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1382"}], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Referred to Com. on TRANS.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on TRANS.", "entity_type": "organi