{"legislative_session": "20252026", "identifier": "AB2435", "title": "Land surveyors: practice without authorization: penalties.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Landsurveyors", "penalties", "practicewithoutauthorization"], "abstracts": [{"note": "summary", "abstract": "Existing law, the Professional Land Surveyors' Act, provides for the licensure and regulation of land surveyors by the Board for Professional Engineers, Land Surveyors, and Geologists. The act prohibits a person from practicing land surveying unless appropriately licensed or specifically exempted from licensure. Under the act, a person who practices, or offers to practice, land surveying without applicable legal authorization is guilty of a misdemeanor.\n\nThis bill would specify tiered penalties, including specified fines and jail time, for a first, 2nd, or 3rd conviction for practicing land surveying without legal authorization."}], "other_titles": [{"note": "", "title": "Land surveyors."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2435"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on B. & P.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on B. & P.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on B. & P. Read second time and amended.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification"