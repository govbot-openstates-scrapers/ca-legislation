{"legislative_session": "20252026", "identifier": "AB2062", "title": "Security cameras: access and use of content.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Securitycameras", "accessanduseofcontent"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes various privacy protections relating to the collection, use, sale, or distribution of personal information, images, or video recordings, including restrictions relating to the retention, access, use, sale, or sharing of images or video recordings collected through the operation of an in-vehicle camera.\n\nThis bill would prohibit a security camera company, as defined, from distributing, selling, or otherwise authorizing a third party to access, use, or distribute video, images, or data obtained from a consumer's security camera without first obtaining the consumer's consent."}], "other_titles": [{"note": "", "title": "Personal information: data breaches."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2062"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 21.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on P. & C.P.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on P. & C.P.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on P. & C.P. Read second time and amended.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendme