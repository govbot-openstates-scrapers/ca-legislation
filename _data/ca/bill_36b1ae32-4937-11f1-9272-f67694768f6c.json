{"legislative_session": "20252026", "identifier": "AB1752", "title": "Eminent domain: appraisals.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Eminentdomain", "appraisals"], "abstracts": [{"note": "summary", "abstract": "Existing law, the Eminent Domain Law, authorizes a public entity to exercise the power of eminent domain to acquire property for a public use, as specified. Existing law entitles the owner of a property acquired by eminent domain to specified compensation. Existing law requires a public entity to pay reasonable costs, not to exceed $5,000, of an independent appraisal ordered by the owner of a property that the public entity offers to purchase under the threat of eminent domain.\n\nThis bill would require a public entity that offers to purchase property under a threat of eminent domain related to specified purposes to pay the full reasonable costs of an independent appraisal ordered by the owner."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1752"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 12.", "date": "2026-02-10", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on JUD.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass and re-refer to Com. on APPR. with recommendation: To Consent Calendar. (Ayes 12. Noes 0.) (March 17). Re-referred to Com. on APPR.", "date": "2026-03-17", "organization_id": "~{\"classification\": \"lower\"}", "classification": [