{"legislative_session": "20252026", "identifier": "AB2793", "title": "California Gambling Control Commission.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["CaliforniaGamblingControlCommission"], "abstracts": [{"note": "summary", "abstract": "Existing law, the Gambling Control Act, provides for the licensure and regulation of various legalized gambling activities and establishments by the California Gambling Control Commission and the investigation and enforcement of those activities by the Department of Justice. Under existing law, the commission consists of 5 members who are appointed by the Governor, subject to confirmation by the Senate. Existing law requires one member of the commission, among other criteria, to be an attorney with regulatory law experience.\n\nThis bill would instead require one member of the commission, among other criteria, to be an attorney with regulatory or gaming law experience. The bill would make other technical, nonsubstantive changes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2793"}], "actions": [{"description": "Read first time. To print.", "date": "2026-03-17", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee April 17.", "date": "2026-03-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on G.O.", "date": "2026-03-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on G.O.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Committee on Governmental Organization", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Committee on Governmental Organization\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "AB2793", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB2793", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "03/17/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB2793&version=20250AB279399INT", "media_type": "application/pdf"}], "date": "2026-03-17", "classification": ""}], "documents": [{"note": "04/21/26- Assembly Governmental Organization", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billAnalysisClient.xhtml?bill_id=202520260AB2793&analysisId=396822&analyzingOffice=Assembly+Governmental+Organization", "media_type": "application/pdf"}], "date": "2026-04-21", "classification": "analysis"}], "citations": [], "sources": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB2793", "note": ""}], "extras": {"impact_clause": "An act to amend Sections 19800 and 19812 of the Business and Professions Code, relating to gambling.", "tags": []}, "jurisdiction": {"id": "ocd-jurisdiction/country:us/state:ca/government", "name": "California", "classification": "state", "division_id": "ocd-division/country:us/state:ca"}, "scraped_at": "2026-04-23T09:59:54+00:00", "_id": "2d6963d8-3efb-11f1-bfd0-ee9ac702f817"}