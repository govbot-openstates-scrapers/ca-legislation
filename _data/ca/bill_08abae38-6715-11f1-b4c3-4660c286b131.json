{"legislative_session": "20252026", "identifier": "SB685", "title": "Special education: nonpublic schools and agencies.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Specialeducation", "nonpublicschoolsandagencies"], "abstracts": [{"note": "summary", "abstract": "Existing law sets forth a method for providing special education and related services to pupils with exceptional needs. Existing law permits, under certain circumstances, contracts to be entered into for the provision of those services by nonpublic, nonsectarian schools or agencies. Existing law defines \"nonpublic, nonsectarian school\" and \"nonpublic, nonsectarian agency\" for these purposes.\n\nThis bill would revise those definition provisions to instead define \"nonpublic school\" and \"nonpublic agency.\" The bill would specify that all references in law to \"nonpublic, nonsectarian school\" or \"nonpublic, nonsectarian agency\" shall instead refer to \"nonpublic school\" or \"nonpublic agency,\" thereby eliminating the requirement that nonpublic schools or agencies that enter into contracts for the provision of special education services be nonsectarian."}], "other_titles": [{"note": "", "title": "California State University: financial aid for homeless students: pilot program."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb685"}], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2025-02-21", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 24.", "date": "2025-02-24", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2025-02-24", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "R