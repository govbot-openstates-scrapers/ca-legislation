{"legislative_session": "20252026", "identifier": "AB2674", "title": "Financial abuse and deception: preventive measures.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Financialabuseanddeception", "preventivemeasures"], "abstracts": [{"note": "summary", "abstract": "Existing law generally regulates financial institutions, including the California Consumer Financial Protection Law that, among other things, requires the Department of Financial Protection and Innovation to exercise nonexclusive oversight and enforcement authority under California consumer financial laws.\n\nThis bill would require a depository institution, as defined, to take certain actions that would help protect its customers from financial abuse and deception, as defined, including by requiring a depository institution that suspects financial abuse or deception with respect to any transaction to employ certain preventive measures, as prescribed, except as specified."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2674"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Coms. on B. & F. and JUD.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Coms. on B. & F. and JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "Assembly Rule 56 suspended. (Page 4580.)", "date": "2026-04-13", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "(Pending re-refer to Co