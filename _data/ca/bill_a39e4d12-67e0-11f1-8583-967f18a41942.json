{"legislative_session": "20252026", "identifier": "AB2596", "title": "Mobilehome parks: federally approved housing programs: compliance with state and local laws.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Mobilehomeparks", "compliancewithstateandlocallaws", "federallyapprovedhousingprograms"], "abstracts": [{"note": "summary", "abstract": "Existing law, the Mobilehome Residency Law, prescribes various terms and conditions of tenancies in mobilehome parks.\n\nThis bill would specify that, if a mobilehome park operator or owner fails to comply with federal law or other federal requirements imposed in connection with a federally approved housing program, the mobilehome park operator or owner shall ensure ongoing compliance with applicable state laws, including, but not limited to, prescribed provisions of the Unruh Civil Rights Act, and local ordinances."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2596"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Coms. on H. & C.D. and JUD.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Coms. on H. & C.D. and JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass and re-refer to Com. on JUD. with recommendation: To Consent Calendar. (Ayes 12. Noes 0.) (April 15). Re-referred to Com. on JUD.", "date": "2026-04-15", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage", "committee