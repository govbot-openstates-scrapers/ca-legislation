{"legislative_session": "20252026", "identifier": "SB1360", "title": "County central committee elections: tie votes.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Countycentralcommitteeelections", "tievotes"], "abstracts": [{"note": "summary", "abstract": "Under existing law, if a tie vote occurs in an election for member of a county central committee, and if the office is to be voted for wholly within one county, the election board shall summon the candidates who received tie votes to appear before the board, and the board shall determine the tie by lot.\n\nThis bill would make a nonsubstantive change to the above provision."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Cervantes", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Cervantes\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "SB1360", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260SB1360", "media_type": "text/html"}], "date": "", "classification": ""}, {"