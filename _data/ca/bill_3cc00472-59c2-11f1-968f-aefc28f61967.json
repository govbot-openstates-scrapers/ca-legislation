{"legislative_session": "20252026", "identifier": "SB1300", "title": "California Global Warming Solutions Act of 2006: report.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["CaliforniaGlobalWarmingSolutionsActof2006", "report"], "abstracts": [{"note": "summary", "abstract": "The California Global Warming Solutions Act of 2006 designates the State Air Resources Board as the state agency charged with monitoring and regulating sources of emissions of greenhouse gases. The act requires the state board to prepare and approve a scoping plan for achieving the maximum technologically feasible and cost-effective reductions in greenhouse gas emissions and to update the scoping plan at least once every 5 years. Existing law requires the state board to present an informational report on topics related to the scoping plan, as directed by the Joint Legislative Committee on Climate Change Policies, at least once a year at a hearing of the joint committee. Existing law requires that report to include a discussion of the regulatory requirements, initiatives, and other programs that influence the implementation of the scoping plan.\n\nThis bill would also require that report to include a discussion of international agreements on the topic of climate change or clean technology innovation that influence the implementation of the scoping plan."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1300"}], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classi