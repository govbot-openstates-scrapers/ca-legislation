{"legislative_session": "20252026", "identifier": "SB1293", "title": "State highways: projects: notice.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Statehighways", "notice", "projects"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes the Department of Transportation and requires it to improve and maintain the state highways, as provided.\n\nThis bill would require the department to provide written notice of certain construction or maintenance projects within the right-of-way of a state highway in a county with a population of 60,000 people or fewer to a person who resides in, or a business that is located within, 5 miles of the project limits, as specified. The bill would also require the department to place the notice on its internet website."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1293"}], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Referred to Com. on TRANS.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on TRANS.", "entity_type": "organization", "organization_id": null}]}, {"description": "Set for hearing April 14.", "date": "2026-03-26", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "From committee with au