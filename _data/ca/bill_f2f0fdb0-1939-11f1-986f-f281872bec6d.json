{"legislative_session": "20252026", "identifier": "SB1344", "title": "Civil actions: housing development projects.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Civilactions", "housingdevelopmentprojects"], "abstracts": [{"note": "summary", "abstract": "Existing law provides that in a civil action brought by a plaintiff to challenge a housing development project that meets or exceeds the requirements for low- or moderate-income housing, a defendant may seek an order requiring the plaintiff to furnish an undertaking as security for costs and damages that may be incurred by the defendant if the bringing of the action would result in preventing or delaying the project, as specified.\n\nThis bill would make a nonsubstantive change to that provision."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Cabaldon", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Cabaldon\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "SB1344", "links": [{"url": "http://leginfo.legislature.ca.go