{"legislative_session": "20252026", "identifier": "AB2145", "title": "Mortgages: principal residence.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Mortgages", "principalresidence"], "abstracts": [{"note": "summary", "abstract": "Existing law generally regulates mortgages and mortgage servicers, including, among other things, prohibiting the acceleration of a loan secured by a mortgage upon specified transfers of residential real property.\n\nThis bill would authorize a borrower who has reached retirement age to transfer the interest rate and remaining loan term secured by a mortgage on residential real property to a mortgage secured by a new principal residence, as specified."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2145"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 21.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on JUD.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Amend, and do pass as amended. (Ayes 10. Noes 0.) (April 28).", "date": "2026-04-28", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "committee-passage"], "related_entities": []}], "sponsorships": [{"name": "Garcia", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Garcia\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "AB2145"