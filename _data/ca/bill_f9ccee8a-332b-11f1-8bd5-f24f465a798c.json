{"legislative_session": "20252026", "identifier": "AB2690", "title": "Civil actions: provisional remedies: injunctions.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Civilactions", "injunctions", "provisionalremedies"], "abstracts": [{"note": "summary", "abstract": "Existing law provides that any person who lives, works, owns property, or attends school in the jurisdiction of a local agency, as defined, who is assessed for and is liable to pay, or within one year before the commencement of the action, has paid, a tax in the local agency, may maintain an action to obtain a judgment restraining and preventing an illegal expenditure of, waste of, or injury to the estate, funds, or other property of the local agency, as specified. Under existing law, a tax that funds the defendant local agency is sufficient to confer standing as a taxpayer, including, but not limited to, an income tax, a sales and use tax or transaction and use tax initially paid by a consumer to a retailer, a property tax, or a business license tax.\n\nThis bill would expand the scope of this cause of action and standing to permit a person to maintain an action against the state or a state entity."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2690"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on JUD.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "F