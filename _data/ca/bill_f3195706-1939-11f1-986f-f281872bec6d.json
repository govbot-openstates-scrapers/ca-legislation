{"legislative_session": "20252026", "identifier": "SB1362", "title": "DREAM grant program.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["DREAMgrantprogram"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes the California DREAM Loan Program, which provides a student attending a participating campus of the University of California or California State University with a loan, referred to as a DREAM loan, if the student satisfies specified requirements. Existing law also authorizes participating institutions to award DREAM grants to grant-eligible students, as defined, if the institution has unawarded funds in the institution's DREAM revolving fund, as specified.\n\nThis bill would make a nonsubstantive change to the provision establishing the DREAM grant program."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Gonzalez", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Gonzalez\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "SB1362", "links": [{"u