{"legislative_session": "20252026", "identifier": "AB1544", "title": "Court proceedings: media access.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Courtproceedings", "mediaaccess"], "abstracts": [{"note": "summary", "abstract": "The California Constitution vests the judicial power of the state in the Supreme Court, courts of appeal, and superior courts. Existing law requires the sittings of every court to be public, except as authorized.\n\nThis bill would bar a judicial officer, peace officer, or other law enforcement officer from prohibiting a member of the press or public from accessing court proceedings that are open to the public. The bill would authorize a violation of that provision to be subject to civil penalties, as specified."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1544"}], "actions": [{"description": "Read first time. To print.", "date": "2026-01-05", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee February 5.", "date": "2026-01-06", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Coms. on PUB. S. and JUD.", "date": "2026-02-17", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Coms. on PUB. S. and JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on PUB. S. Read second time and amended.", "date": "2026-03-17", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred to Com. on PUB. S.", "date": "2026-03-18", "organization_id":