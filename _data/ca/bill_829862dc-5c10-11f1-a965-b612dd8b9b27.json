{"legislative_session": "20252026", "identifier": "SB1423", "title": "Active Transportation Program: report.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["ActiveTransportationProgram", "report"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes the Active Transportation Program in the Department of Transportation for the purpose of encouraging increased use of active modes of transportation, such as biking and walking. Existing law requires the California Transportation Commission to develop guidelines and project selection criteria for the program and requires the guidelines to address, among other things, application timelines and application rating and ranking criteria.\n\nThis bill would require the commission, on or before January 1, 2028, to conduct a study, and submit a report to the Legislature, on opportunities to improve equity, accessibility, cost-effectiveness, and the ease of application for prospective applicants for the Active Transportation Program, as specified. The bill would repeal these provisions on January 1, 2032."}], "other_titles": [{"note": "", "title": "Transportation funding: State Transportation Improvement Program: Active Transportation Program."}, {"note": "", "title": "Wildfire prevention: California Wildfire Mitigation Financial Assistance Program."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1423"}], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classificatio