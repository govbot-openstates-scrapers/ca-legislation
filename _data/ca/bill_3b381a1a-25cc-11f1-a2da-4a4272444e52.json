{"legislative_session": "20252026", "identifier": "AB2691", "title": "Elections: elective office: felony conviction.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Elections", "electiveoffice", "felonyconviction"], "abstracts": [{"note": "summary", "abstract": "Existing law prohibits the consideration of a person as a candidate for, and provides that the person is not eligible to be elected to, any state or local elective office if the person has been convicted of a felony involving accepting or giving, or offering to give, any bribe, the embezzlement of public money, extortion or theft of public money, perjury, or conspiracy to commit any of those crimes.\n\nThis bill would additionally prohibit the consideration of a person as a candidate for, and provide that the person is not eligible to be elected to, any state or local elective office if they have been convicted of a felony involving sexual assault or human trafficking, as defined."}], "other_titles": [{"note": "", "title": "Elections: domicile."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2691"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on ELECTIONS.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on ELECTIONS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on ELECTIONS. Read second time and amended.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred to Com. on ELECTIONS.", "date": "2026-03-17", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on ELECTIONS.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Addis", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Addis\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "AB2691", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB2691", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "02/20/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB2691&version=20250AB269199INT", "media_type": "application/pdf"}], "date": "2026-02-20", "classification": ""}, {"note": "03/16/26 - Amended Assembly", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB2691&version=20250AB269198AMD", "media_type": "application/pdf"}], "date": "2026-03-16", "classification": ""}], "documents": [], "citations": [], "sources": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB2691", "note": ""}], "extras": {"impact_clause": "An act to amend Section 20 of the Elections Code, relating to elections.", "tags": []}, "jurisdiction": {"id": "ocd-jurisdiction/country:us/state:ca/government", "name": "California", "classification": "state", "division_id": "ocd-division/country:us/state:ca"}, "scraped_at": "2026-03-22T08:50:52+00:00", "_id": "3b381a1a-25cc-11f1-a2da-4a4272444e52"}