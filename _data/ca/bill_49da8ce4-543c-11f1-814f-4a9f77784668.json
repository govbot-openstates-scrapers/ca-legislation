{"legislative_session": "20252026", "identifier": "ACR207", "title": "Relative to California Hindu American Awareness and Appreciation Month.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["concurrent resolution"], "subject": ["CaliforniaHinduAmericanAwarenessandAppreciationMonth"], "abstracts": [{"note": "summary", "abstract": "This measure would designate the month of October 2026 as California Hindu American Awareness and Appreciation Month. The measure would also recognize and acknowledge the significant contributions made by Californians of Hindu heritage to the state and seek to increase awareness and understanding of the Hindu American community, and would condemn all hate crimes and bias incidents against Hindu Americans, Hindu temples and centers, and places of significance to the Hindu American community."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-acr207"}], "actions": [{"description": "Introduced. To print.", "date": "2026-05-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer.", "date": "2026-05-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}], "sponsorships": [{"name": "Kalra", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Kalra\"}", "organization_id": null}, {"name": "Patel", "classification": "author", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Patel\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "ACR207", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260ACR207", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "05/18/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260ACR207&version=20250ACR2079