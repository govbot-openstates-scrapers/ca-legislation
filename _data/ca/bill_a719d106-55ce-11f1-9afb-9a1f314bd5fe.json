{"legislative_session": "20252026", "identifier": "AB2711", "title": "Oil and gas: notice of intention.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Oilandgas", "noticeofintention"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes the Geologic Energy Management Division in the Department of Conservation, under the direction of the State Oil and Gas Supervisor, who is required to supervise the drilling, operation, maintenance, and abandonment of oil and gas wells in the state. Existing law requires the operator of a well to file a written notice of intention to commence drilling with, and prohibits any drilling until approval is given by, the supervisor or district deputy. Under existing law, if the supervisor or district deputy fails to give the operator written response to the notice within 10 working days from the date of receipt, that failure to respond is considered an approval, as specified. Under existing law, if operations have not commenced within 24 months of receipt of the notice by the supervisor or the district deputy, the notice is deemed canceled, as provided.\n\nThis bill would instead require, if the supervisor or district deputy fails to give the operator an approval or denial of the notice of intent to commence drilling within 30 working days, provided that all necessary environmental and technical reviews are complete, failure to be considered an approval. The bill would also require, if the notice is denied by the supervisor or district deputy, within 30 working days, the supervisor or the district deputy to include in the denial a rational explanation for why the notice was denied. The bill would instead provide that if operations have not commenced within 24 months of receipt of approval of the notice by the supervisor or the district deputy, the notice is deemed canceled, as provided."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2711"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on NAT. RES.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on NAT. RES.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Amend, and do pass as amended and re-refer to Com. on APPR. (Ayes 8. Noes 0.) (April 20).", "date": "2026-04-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "committee-passage", "referral-committee"], "related_entities": []}, {"description": "Read second time and amended.", "date": "2026-04-22", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred to Com. on APPR.", "date": "2026-04-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on APPR.", "entity_type": "organization", "organization_id": null}]}, {"description": "In committee: Set, first hearing. Referred to APPR. suspense file.", "date": "2026-05-13", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "APPR", "entity_type": "organization", "organization_id": null}, {"name": "APPR. suspense file.", "entity_type": "organization", "organization_id": null}]}, {"description": "Joint Rule 62(a), file notice suspended.", "date": "2026-05-14", "organization_id": "~{