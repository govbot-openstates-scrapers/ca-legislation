{"legislative_session": "20252026", "identifier": "AB1616", "title": "Veterans.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Veterans"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes the Department of Veterans Affairs. The department, among other services, provides veterans and their dependents and survivors with assistance in processing service-related disability claims, assistance in obtaining affordable housing, and information about health ailments associated with military service.\n\nThis bill, upon appropriation by the Legislature, would require the department to establish a program to fund a study for nonnarcotic post-traumatic stress disorder treatments. The bill would require the department to submit a report that summarizes the findings and recommendations of the study to the Legislature no later than June 30, 2030, and would repeal these provisions on January 1, 2031."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1616"}], "actions": [{"description": "Read first time. To print.", "date": "2026-01-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee February 21.", "date": "2026-01-22", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on M. & V.A.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on M. & V.A.", "entity_type": "organization", "organization_id": null}]}, {"description": "Coauthors revised.", "date": "2026-03-25", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "From committee: Do pass and re-refer to Com. on APPR. with recommendation: To Consent C