{"legislative_session": "20252026", "identifier": "SB880", "title": "Residential property: contract: fees.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Residentialproperty", "contract", "fees"], "abstracts": [{"note": "summary", "abstract": "Existing law prohibits the vendor or lessor of a single-family residential property from contracting for or exacting any fee in excess of $10 for the act of signing and delivering a document in connection with the transfer, cancellation, or reconveyance of any title or instrument at the time the buyer or lessee exercises an option to buy, or completes performance of the contract for the sale of, the property.\n\nThis bill would modify that prohibition by extending it to the vendor or lessor of any residential property."}], "other_titles": [{"note": "", "title": "Housing purchases: moratorium."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb880"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-01-12", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after February 12.", "date": "2026-01-13", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-02-11", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee with author's amendments. Read second time and amended. Re-referred to Com. on RLS.", "date": "2026-03-25", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["amendment-passage", "committee-passage", "reading-1", "reading-2", "referral-committee"], "rel