{"legislative_session": "20252026", "identifier": "SCR110", "title": "Relative to Women's Military History Week.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["concurrent resolution"], "subject": ["Women'sMilitaryHistoryWeek"], "abstracts": [{"note": "summary", "abstract": "This measure would recognize \"Women Warriors\" by proclaiming the week of March 16, 2026, to March 22, 2026, inclusive, as Women's Military History Week in California, recognize the hard-fought contributions of women to the military and freedom, and encourage Californians to honor the courageous sacrifices that women have made since the historic lifting of the ban on women in combat on January 24, 2013."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-scr110"}], "actions": [{"description": "Introduced. Referred to Com. on RLS.", "date": "2026-01-14", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Ordered to third reading.", "date": "2026-01-21", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["committee-passage"], "related_entities": []}, {"description": "Read. Adopted. (Ayes 34. Noes 0. Page 3559.) Ordered to the Assembly.", "date": "2026-03-12", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["amendment-passage", "passage", "reading-1"], "related_entities": []}, {"description": "In Assembly. Held at Desk.", "date": "2026-03-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-03-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization