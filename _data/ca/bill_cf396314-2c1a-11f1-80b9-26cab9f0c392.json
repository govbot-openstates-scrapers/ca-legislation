{"legislative_session": "20252026", "identifier": "AB2280", "title": "Vehicle liens.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Vehicleliens"], "abstracts": [{"note": "summary", "abstract": "Existing law authorizes a person to place a lien on a registered vehicle for authorized towing, storage, or labor associated with recovery or load salvage of the vehicle, among other things.\n\nThis bill would clarify that provisions relating to vehicle liens do not prohibit a licensed repossession agency from filing a lien."}], "other_titles": [{"note": "", "title": "Department of Consumer Affairs."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2280"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on TRANS.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on TRANS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on TRANS. Read second time and amended.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred to Com. on TRANS.", "date": "2026-03-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on TRANS.", "entity_type": "organization", "organization_id": null}]}], "sponsorshi