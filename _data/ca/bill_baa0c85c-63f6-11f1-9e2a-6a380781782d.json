{"legislative_session": "20252026", "identifier": "ACR192", "title": "Relative to the Little Saigon DMV.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["concurrent resolution"], "subject": ["LittleSaigonDMV"], "abstracts": [{"note": "summary", "abstract": "This measure would designate the Department of Motor Vehicles (DMV) field office located at 13700 Hoover Street in the City of Westminster as the Little Saigon DMV. The measure would request the Department of General Services to determine the cost of erecting appropriate signage commemorating this special designation and, upon receiving donations from nonstate sources covering that cost, to erect that signage."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-acr192"}], "actions": [{"description": "Introduced. To print.", "date": "2026-05-04", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer.", "date": "2026-05-05", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on TRANS.", "date": "2026-05-11", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on TRANS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on TRANS. Amended.", "date": "2026-06-08", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction"], "related_entities": []}], "sponsorships": [{"name": "Ta", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Ta\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "ACR192", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260ACR192"