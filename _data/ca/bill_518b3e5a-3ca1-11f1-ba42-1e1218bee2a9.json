{"legislative_session": "20252026", "identifier": "SB1186", "title": "Expedited birth certificates upon adoption.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Expeditedbirthcertificatesuponadoption"], "abstracts": [{"note": "summary", "abstract": "Existing law requires the State Registrar to establish a new birth certificate upon receipt of a report of adoption or a readoption order, as specified.\n\nThis bill would require the State Registrar to establish a new birth certificate pursuant to the provisions above within 11 weeks upon receipt of a report of adoption or a readoption order."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1186"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on HEALTH.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on HEALTH.", "entity_type": "organization", "organization_id": null}]}, {"description": "Set for hearing April 15.", "date": "2026-03-26", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "From committee: Do pass as amended and re-refer to Com. on APPR. with recommendation: To consent calendar. (Ayes 10. Noes 0.) (April 15).", "date": "2026-04-16", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["amendment-passage", "committee-passage", "committee-passage-favorable"], "related_entities": []}], "sponsorshi