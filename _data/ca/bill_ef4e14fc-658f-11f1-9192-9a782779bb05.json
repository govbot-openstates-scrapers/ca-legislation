{"legislative_session": "20252026", "identifier": "SB1029", "title": "Vehicle lien sales: Department of Motor Vehicles: notice.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["DepartmentofMotorVehicles", "Vehicleliensales", "notice"], "abstracts": [{"note": "summary", "abstract": "Existing law requires that the proceeds of a vehicle lien sale be paid to the lienholder in the amount necessary to discharge the lien and to cover the cost of processing the vehicle. Existing law requires that the balance be forwarded to the Department of Motor Vehicles, as provided. Existing law authorizes any person claiming an interest in the vehicle to file a claim with the Department of Motor Vehicles for any portion of the funds from the lien sale that was forwarded to the department, as provided.\n\nThis bill would require the Department of Motor Vehicles, within 14 days of receiving the balance, to provide prescribed notice about the funds from the lien sale that were forwarded to the department and the process to file a claim, as described above, to specified individuals, including the registered and legal owners of the vehicle."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1029"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-02-10", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 13.", "date": "2026-02-11", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on TRANS.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on TRANS.", "entity_type": "organization", "organization_id": null}]},