{"legislative_session": "20252026", "identifier": "SCR176", "title": "Relative to National Small Business Month.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["concurrent resolution"], "subject": ["NationalSmallBusinessMonth"], "abstracts": [{"note": "summary", "abstract": "This measure would affirm the important role of small businesses and workplaces as vital pathways for addressing the mental health crisis, reducing stigma, promoting early intervention, and expanding culturally responsive care. The measure would recognize May 2026 as National Small Business Month in California and encourage the people of the State of California to support small businesses. The measure would also recognize the CalAsian Foundation and its members for their courage, innovation, and commitment to advancing mental health awareness, prevention, healing, and care across small business communities statewide."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-scr176"}], "actions": [{"description": "Introduced. Referred to Com. on RLS.", "date": "2026-05-05", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Ordered to third reading.", "date": "2026-05-13", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["committee-passage"], "related_entities": []}], "sponsorships": [{"name": "Ashby", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Ashby\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "SCR176", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260SCR176", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "05/05/26 - Introduced", "links": [{"url": "https://leginfo