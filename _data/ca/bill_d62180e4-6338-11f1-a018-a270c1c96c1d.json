{"legislative_session": "20252026", "identifier": "AB2402", "title": "Health studio contracts: fee limits: multiservice health club studio.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Healthstudiocontracts", "feelimits", "multiservicehealthclubstudio"], "abstracts": [{"note": "summary", "abstract": "Existing law generally regulates contracts for health studio services, as defined, including prohibiting those contracts, beginning January 1, 2010, from requiring payment in excess of $4,400, inclusive of initiation or initial membership fees and exclusive of interest or finance charges, by the person receiving the services or use of the facilities. \n\nThis bill would exempt a multiservice health club studio from the above-described provision on payment limitations and would define a \"multiservice health club studio\" for these purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2402"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on B. & P.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on B. & P.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on B. & P. Read second time and amended.", "date": "2026-04-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"descripti