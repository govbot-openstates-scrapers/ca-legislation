{"legislative_session": "20252026", "identifier": "SB1106", "title": "Agentic artificial intelligence.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Agenticartificialintelligence"], "abstracts": [{"note": "summary", "abstract": "Existing law requires the Office of Emergency Services to, as appropriate, perform a risk analysis of potential threats posed by the use of generative artificial intelligence to California's critical infrastructure, including those that could lead to mass casualty events. Existing law requires that risk analysis to be provided to the Governor, and, if appropriate, include recommendations reflecting changes to artificial intelligence technology, its applications, and risk management, including further private actions, administrative actions, and collaboration with the Legislature to guard against potential threats and vulnerabilities.\n\nThis bill would require that recommendations in the risk analysis reflecting changes to artificial intelligence technology include agentic artificial intelligence, as defined."}], "other_titles": [{"note": "", "title": "Data brokers."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1106"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-02-13", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 16.", "date": "2026-02-17", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on P., D.T., & C.P.", "date": "2026-02-26", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on P., D.T., & C.P.", "entity_type": "organization", "organization_id": null}]}, {"description": "Set f