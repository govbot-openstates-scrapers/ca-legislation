{"legislative_session": "20252026", "identifier": "SB985", "title": "911 emergency system.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["911emergencysystem"], "abstracts": [{"note": "summary", "abstract": "Existing law requires the Office of Emergency Services to develop a plan and timeline of target dates for the testing, implementation, and operation of a Next Generation 911 emergency communication system, including text to 911 service, throughout California.\n\nThis bill would require the office to provide quarterly reports to the Legislature on the development, implementation, and spending on the Next Generation 911 system, as specified."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb985"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-02-05", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 8.", "date": "2026-02-09", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Coms. on E., U & C. and E.M.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Coms. on E., U & C. and E.M.", "entity_type": "organization", "organization_id": null}]}, {"description": "Set for hearing March 17.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "From committee: Do pass as amended and re-refer to Com. on E.M. (Ayes 15. Noes 0.) (March 17).", "date": "2026-03-19", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["amendment-passage", "committee-passage", "committee-passage-favorable"], "