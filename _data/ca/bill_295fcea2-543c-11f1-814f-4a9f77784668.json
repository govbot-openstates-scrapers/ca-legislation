{"legislative_session": "20252026", "identifier": "AB2360", "title": "State agencies: governmental linguistics.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Stateagencies", "governmentallinguistics"], "abstracts": [{"note": "summary", "abstract": "Existing law requires each department, commission, office, or other administrative agency of state government to write each document, as defined, that it produces in plain, straightforward language, avoiding technical terms as much as possible, and using a coherent and easily readable style.\n\nThis bill would instead require each state agency, as described above, to write each document it produces after January 1, 2027, either digitally or in print, in plain language, as specified, and would define \"plain language\" for purposes of that provision. The bill would authorize a state agency, as described above, to use standards created by the Office of Data and Innovation that identify how a state agency incorporates plain language principles and practices. The bill would require the head of each state agency to, among other things, designate one or more senior officials within the state agency to oversee state agency implementation of these provisions."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2360"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on G.O.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on G.O.", "entity_type": "organization", "organizati