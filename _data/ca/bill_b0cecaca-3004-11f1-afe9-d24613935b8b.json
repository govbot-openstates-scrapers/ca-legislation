{"legislative_session": "20252026", "identifier": "AB2372", "title": "Vehicles: tolls.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Vehicles", "tolls"], "abstracts": [{"note": "summary", "abstract": "Existing law provides for the exemption of authorized emergency vehicles from the payment of a toll or charge on a vehicular crossing, toll highway, or high-occupancy toll (HOT) lane, when the authorized emergency vehicle is being driven under specified conditions, including, among others, the vehicle is displaying an exempt license plate and properly identified or marked as an authorized emergency vehicle, as specified.\n\nThis bill would exempt a vehicle that is not displaying an exempt license plate if it is otherwise exempted from the above-described payment and is authorized as an emergency vehicle by the California Highway Patrol."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2372"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on TRANS.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on TRANS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on TRANS. Read second time and amended.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "R