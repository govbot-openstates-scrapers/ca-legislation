{"legislative_session": "20252026", "identifier": "AB1875", "title": "Dissolution of marriage.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Dissolutionofmarriage"], "abstracts": [{"note": "summary", "abstract": "Existing law governs the dissolution of marriage and legal separation. Existing law prohibits a judgment of dissolution of marriage from being made final until 6 months have expired from the date of service of a copy of the summons and petition or the date of appearance of the respondent, whichever occurs first. Existing law authorizes a court to extend the 6-month period for good cause shown. Existing law also requires a court to enter a judgment dissolving a marriage when 6 months have expired from the date of the filing of a joint petition for summary dissolution, unless a revocation has been filed.\n\nThis bill would additionally authorize the court to reduce or waive the 6-month period described above for good cause shown."}], "other_titles": [{"note": "", "title": "Confidential marriage."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1875"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 15.", "date": "2026-02-13", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on JUD.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on JUD. Read second time and amended.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred to Com. on JUD.", "date": "2026-03-03", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass. To Consent Calendar. (Ayes 12. Noes 0.) (March 17).", "date": "2026-03-17", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage", "committee-passage-favorable"], "related_entities": []}, {"description": "Read second time. Ordered to Consent Calendar.", "date": "2026-03-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1", "reading-2"], "related_entities": []}, {"description": "Read third time. Passed. Ordered to the Senate. (Ayes 67. Noes 0. Page 4373.)", "date": "2026-03-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["passage", "reading-1", "reading-3"], "related_entities": []}, {"description": "In Senate. Read first time. To Com. on RLS. for assignment.", "date": "2026-03-24", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Referred to Com. on JUD.", "date": "2026-05-06", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Hart", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Hart\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "AB1875", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB1875", "media_type": "text/html"}], "date": "", "classific