{"legislative_session": "20252026", "identifier": "AB2584", "title": "Self-defense.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Self-defense"], "abstracts": [{"note": "summary", "abstract": "Existing law authorizes necessary force to be used to protect from wrongful injury the person or property of oneself, or of a spouse, child, parent, or other relative, or member of one's family, or of a ward, servant, master, or guest.\n\nThis bill, the Preemptive Self Defense Act of 2026, would also specify that there shall not be any civil liability on the part of, and no cause of action shall accrue against, a person who lawfully resists a public offense, as specified."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2584"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Coms. on PUB. S. and JUD.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Coms. on PUB. S. and JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Amend, and do pass as amended and re-refer to Com. on JUD. (Ayes 8. Noes 0.) (March 24).", "date": "2026-03-25", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "committee-passage", "referral-committee"], "related_entities": []}, {"description": "Read second time and amended.", "date": "2026-03-26", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-passage", 