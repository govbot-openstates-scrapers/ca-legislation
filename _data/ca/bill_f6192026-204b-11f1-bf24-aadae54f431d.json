{"legislative_session": "20252026", "identifier": "SB962", "title": "Emergency vehicles: blue warning lights.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Emergencyvehicles", "bluewarninglights"], "abstracts": [{"note": "summary", "abstract": "Existing law authorizes specified peace officers, including, among others, police officers, probation officers, and members of the California National Guard, in the performance of the officers' duties, to display a steady or flashing blue warning light visible from the front, sides, or rear of their emergency vehicles.\n\nThis bill, the Agent Joshua Byrd Memorial Act, would additionally authorize parole officers to display the blue warning light from their emergency vehicles if they complete a 4-hour classroom training course regarding the operation of emergency vehicles that is certified by the Commission on Correctional Peace Officer Standards and Training."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-02-03", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 6.", "date": "2026-02-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-02-11", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee with author's amendments. Read second time and amended. Re-referred to Com. on RLS.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["amendment-passage", "committee-passage", "reading-1", "reading-2", "referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Archuleta", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Archuleta\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "SB962", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260SB962", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "02/03/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260SB962&version=20250SB96299INT", "media_type": "application/pdf"}], "date": "2026-02-03", "classification": ""}, {"note": "03/09/26 - Amended Senate", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260SB962&version=20250SB96298AMD", "media_type": "application/pdf"}], "date": "2026-03-09", "classification": ""}], "documents": [], "citations": [], "sources": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260SB962", "note": ""}], "extras": {"impact_clause": "An act to amend Section 25258 of the Vehicle Code, relating to vehicles.", "tags": ["fiscal committee"]}, "jurisdiction": {"id": "ocd-jurisdiction/country:us/state:ca/government", "name": "California", "classification": "state", "division_id": "ocd-division/country:us/state:ca"}, "scraped_at": "2026-03-15T08:50:04+00:00", "_id": "f6192026-204b-11f1-bf24-aadae54f431d"}