{"legislative_session": "20252026", "identifier": "AB2181", "title": "Public Utilities Commission.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["PublicUtilitiesCommission"], "abstracts": [{"note": "summary", "abstract": "The California Constitution establishes the Public Utilities Commission, which consists of 5 members appointed by the Governor and approved by the Senate. Existing law vests the commission with regulatory authority over public utilities.\n\nThis bill would require the Governor, in appointing members of the commission, to ensure a diverse composition of commissioners by considering geographic diversity and other factors."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2181"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on U. & E.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on U. & E.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass and re-refer to Com. on APPR. with recommendation: To Consent Calendar. (Ayes 18. Noes 0.) (April 22). Re-referred to Com. on APPR.", "date": "2026-04-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage", "committee-passage-favorable", "referral-committee"], "related_entities": [{"name": "Com. on APPR.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass. To Consent Calendar. (Ayes 15. Noes 0.) (May 13).", "