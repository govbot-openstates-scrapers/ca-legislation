{"legislative_session": "20252026", "identifier": "AB2412", "title": "State agencies or departments: public communications.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Stateagenciesordepartments", "publiccommunications"], "abstracts": [{"note": "summary", "abstract": "Existing law requires a state agency or department that utilizes generative artificial intelligence (GenAI) to directly communicate with a person regarding government services and benefits to ensure that those communications include a disclaimer that indicates to the person that the communication was generated by GenAI, as specified, and information describing how a person may contact a human employee of the state agency or department.\n\nThis bill would instead require that disclaimer when a state agency or department communicates with the public, as specified."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2412"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on P. & C.P.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on P. & C.P.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Amend, and do pass as amended and re-refer to Com. on APPR. with recommendation: To Consent Calendar. (Ayes 15. Noes 0.) (April 7).", "date": "2026-04-08", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "committee-passage", "referral-committ