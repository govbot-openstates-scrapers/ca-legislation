{"legislative_session": "20252026", "identifier": "AB2524", "title": "Pupils: work permits: juvenile court.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Pupils", "juvenilecourt", "workpermits"], "abstracts": [{"note": "summary", "abstract": "Existing law authorizes the superintendent of a school district in which a minor resides, the chief executive officer of a charter school, the county superintendent of schools, the principal of a public or private school, or specified school employees authorized by the superintendent of a school district, chief executive officer, or county superintendent of schools in writing, to issue a work permit to a pupil upon receipt of a written request from a parent, guardian, foster parent, or other specified person, as provided.\n\nThis bill would authorize a work permit to be issued by a juvenile court to minors who are under the jurisdiction of the juvenile court, as provided."}], "other_titles": [{"note": "", "title": "Pupils: work permits."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2524"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on ED.", "date": "2026-03-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on ED.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on ED. Read second time and amended.", "date": "2026-03-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["a