{"legislative_session": "20252026", "identifier": "AB2298", "title": "Pupil instruction: computer science: content standards and instructional materials.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Pupilinstruction", "computerscience", "contentstandardsandinstructionalmaterials"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes the Instructional Quality Commission and requires the commission to, among other things, advise and recommend to the State Board of Education the policies and activities that are needed to implement the state's academic content standards and develop criteria for evaluating instructional materials, as specified.\n\nThis bill would require the commission, when the computer science content standards are next revised after January 1, 2027, to consider incorporating cybersecurity skills, as defined, into those standards. The bill would also require the commission, when the computer science instructional materials are next adopted by the state board after January 1, 2027, to consider including cybersecurity skills in its criteria for evaluating instructional materials."}], "other_titles": [{"note": "", "title": "Cybersecurity."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2298"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on ED.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on ED.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee