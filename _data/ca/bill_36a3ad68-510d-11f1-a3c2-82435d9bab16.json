{"legislative_session": "20252026", "identifier": "AB1920", "title": "Community colleges: California College Promise: fee waiver eligibility.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["CaliforniaCollegePromise", "Communitycolleges", "feewaivereligibility"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes the California College Promise, under the administration of the Chancellor of the California Community Colleges, to provide funding, upon appropriation by the Legislature, to each community college meeting prescribed requirements. Existing law authorizes a community college to use that funding to waive some or all of the fees for 2 academic years for first-time community college students and returning community college students, as defined, who are enrolled in 12 or more semester units or the equivalent, or less for students certified as \"full time,\" as specified, and who complete and submit either a Free Application for Federal Student Aid or a California Dream Act application, except that a student who has previously earned a degree or certificate from a postsecondary educational institution is not eligible for this fee waiver.\n\nThis bill would prohibit a certificate awarded to a student by a postsecondary educational institution as part of a course sequence leading to an associate degree from making the student ineligible for that fee waiver."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1920"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 15.", "date": "2026-02-13", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on HIGHER ED.", "date": "2026-03-