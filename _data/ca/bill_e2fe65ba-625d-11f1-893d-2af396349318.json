{"legislative_session": "20252026", "identifier": "SB239", "title": "Crimes: criminal threats.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Crimes", "criminalthreats"], "abstracts": [{"note": "summary", "abstract": "Existing law makes it a crime to willfully threaten to commit a crime that will result in death or great bodily injury to another person, as specified. Under existing law, this crime is punishable as a misdemeanor or by imprisonment in state prison as a felony. Existing law, for the purposes of sentencing for a felony violation of these provisions, authorizes the court to consider, as a factor in aggravation, that the defendant willfully threatened to commit a crime that would result in the death or great bodily injury of a state constitutional officer, a Member of the Legislature, or a judge or court commissioner, as specified.\n\nThis bill would additionally authorize the court to consider, as a factor in aggravation, that the defendant willfully threatened to commit a crime that would result in the death or great bodily injury of a county or city elections official, or a local agency official, as specified."}], "other_titles": [{"note": "", "title": "Open meetings: teleconferencing: subsidiary body."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb239"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2025-01-30", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 2.", "date": "2025-02-03", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Coms. on L. GOV. and JUD.", "date": "2025-02-14", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_enti