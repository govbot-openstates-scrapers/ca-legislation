{"legislative_session": "20252026", "identifier": "AB2153", "title": "Voter registration: residency confirmation.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Voterregistration", "residencyconfirmation"], "abstracts": [{"note": "summary", "abstract": "Existing law requires county elections officials to update a voter's registration record if change-of-address information indicates the voter has moved to a new residence address in California. Existing law requires county elections officials to change a voter's registration status to inactive if mailings have been returned as undeliverable or if other sources of information indicate that the voter has moved out of state.\n\nThis bill would repeal an obsolete version of these requirements."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2153"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 21.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on ELECTIONS.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on ELECTIONS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass. To Consent Calendar. (Ayes 8. Noes 0.) (March 25).", "date": "2026-03-25", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage", "committee-passage-favorable"], "related_entities": []}, {"description": "Read second time. Ordered to Consent Calendar.", "date": "2026-03-26", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["readin