{"legislative_session": "20252026", "identifier": "AB2685", "title": "Marketing laws: processing strawberries.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Marketinglaws", "processingstrawberries"], "abstracts": [{"note": "summary", "abstract": "Existing law requires the Secretary of Food and Agriculture to prepare and file with the Legislature a written report on the marketing of processing strawberries, as specified.\n\nThis bill would require the secretary to make the report publicly available on the Department of Food and Agriculture's internet website, rather than file the report with the Legislature."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2685"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on AGRI.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on AGRI.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass and re-refer to Com. on APPR. with recommendation: To Consent Calendar. (Ayes 8. Noes 0.) (March 25). Re-referred to Com. on APPR.", "date": "2026-03-26", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage", "committee-passage-favorable", "referral-committee"], "related_entities": [{"name": "Com. on APPR.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Committee on Agriculture", "classification": "author", "entity_type": "person", "primary": true, "pers