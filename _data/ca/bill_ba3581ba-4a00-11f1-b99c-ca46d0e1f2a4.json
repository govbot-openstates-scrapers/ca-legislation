{"legislative_session": "20252026", "identifier": "AB1905", "title": "Juveniles: custodial interrogation.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Juveniles", "custodialinterrogation"], "abstracts": [{"note": "summary", "abstract": "Existing law prohibits law enforcement officers from employing threats, physical harm, deception, or psychologically manipulative interrogation tactics, as specified, during a custodial interrogation of a person 17 years of age or younger.\n\nThis bill would prohibit a law enforcement officer from seeking statements or information while working undercover, or by individuals working in collaboration with, or acting as agents of, law enforcement, from a person who was 17 years of age or younger during the commission of crime and who is in custody. The bill would direct a court to consider any willful failure of a law enforcement officer in violation of these provisions in determining the credibility of that law enforcement officer."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1905"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 15.", "date": "2026-02-13", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on PUB. S.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on PUB. S.", "entity_type": "organization", "organization_id": null}]}, {"description": "Coauthors revised.", "date": "2026-03-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "From committee: Do pass. (Ayes 7. Noes 0.) (March 17).", "date": "2026-03-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage", "committee-passage-favorable"], "related_entities": []}, {"description": "Read second time. Ordered to third reading.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1", "reading-2"], "related_entities": []}], "sponsorships": [{"name": "Schultz", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Schultz\"}", "organization_id": null}, {"name": "Bonta", "classification": "principal coauthor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Bonta\"}", "organization_id": null}, {"name": "Sharp-Collins", "classification": "coauthor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Sharp-Collins\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "AB1905", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB1905", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "02/12/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB1905&version=20250AB190599INT", "media_type": "application/pdf"}], "date": "2026-02-12", "classification": ""}], "documents": [{"note": "03/16/26- Assembly Public Safety", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billAnalysisClient.xhtml?bill_id=202520260AB1905&analysisId=394335&analyzingOffice=Assembly+Public+Safety", "media_type": "application/pdf"}], "date": "2026-03-16", "classification": "analysis"}, {"note": "03/20/26- ASSEMBLY FLOOR ANALYSIS", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billAnalysisClient.xhtml?bill_id=202520260AB1905&analysisId=394488&analyzingOffice=ASSEMBLY+FLOOR+ANALYSIS", "media_type": "application/pdf"}], "date": "2026-03-20", "classification": "analysis"}]