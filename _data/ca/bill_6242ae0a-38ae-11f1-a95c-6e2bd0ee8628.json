{"legislative_session": "20252026", "identifier": "SB1224", "title": "Home protection contracts.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Homeprotectioncontracts"], "abstracts": [{"note": "summary", "abstract": "Existing law regulates home protection companies that issue home protection contracts, as defined, to repair or replace components, systems, and appliances of a home for a specified period of time. Existing law requires the contract to provide a system of service for effectuating a repair or replacement of the system, component, or appliance.\n\nThis bill would require the contract to also include a system of service for cash in lieu of repair or replacement of the system, component, or appliance when it is impossible to effectuate a repair or replacement, when effectuating a repair or replacement exceeds the contract aggregate, or upon request of the consumer."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1224"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on INS.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on INS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee with author's amendments. Read second time and amended. Re-referred to Com. on INS.", "date": "2026-03-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["amendment-passage", "committee-p