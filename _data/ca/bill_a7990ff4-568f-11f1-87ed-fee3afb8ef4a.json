{"legislative_session": "20252026", "identifier": "SB1410", "title": "Adult community care facilities: email address of record.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Adultcommunitycarefacilities", "emailaddressofrecord"], "abstracts": [{"note": "summary", "abstract": "Existing law, the California Community Care Facilities Act, provides for the licensure and regulation of community care facilities by the State Department of Social Services, including various adult residential facilities. Existing law requires an applicant or licensee of an adult community care facility to maintain an email address of record with the department, and to provide written notification to the department of the email address and of any change to the email address within 10 business days of the change.\n\nThis bill would instead require the applicant or licensee to provide the written notification of any change to the email address of record within 12 business days."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1410"}], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Referred to Com. on HUMAN S.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on HUMAN S.", "entity_type": "organization", "organization_id": null}]}, {"description": "Set f