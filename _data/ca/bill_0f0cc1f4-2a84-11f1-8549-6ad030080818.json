{"legislative_session": "20252026", "identifier": "SB916", "title": "Civil actions: housing development projects.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Civilactions", "housingdevelopmentprojects"], "abstracts": [{"note": "summary", "abstract": "Existing law provides that in a civil action brought by a plaintiff to challenge a housing development project that meets or exceeds the requirements for low- or moderate-income housing, a defendant may seek an order requiring the plaintiff to furnish an undertaking as security for costs and damages that may be incurred by the defendant if the bringing of the action would result in preventing or delaying the project, as specified. Existing law authorizes the court to limit the amount of the undertaking or to decline to require the plaintiff to furnish an undertaking if the court determines that, based on evidence submitted by the plaintiff, furnishing an undertaking would cause the plaintiff to suffer undue economic hardship.\n\nThis bill would make these provisions applicable to a student housing development, as defined."}], "other_titles": [{"note": "", "title": "Use of likeness: digital replica."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb916"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-01-27", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after February 27.", "date": "2026-01-28", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-02-11", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_i