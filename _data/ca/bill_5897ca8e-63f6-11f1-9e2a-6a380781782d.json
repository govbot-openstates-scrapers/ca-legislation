{"legislative_session": "20252026", "identifier": "SB1090", "title": "Offers of purchase: real property damaged by wildfire disaster.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Offersofpurchase", "realpropertydamagedbywildfiredisaster"], "abstracts": [{"note": "summary", "abstract": "Existing law describes the rights and obligations of owners of real property, including that the owner of land in fee has the right to the surface and to everything permanently situated beneath or above it.\n\nThis bill would prohibit any individual or entity that owns, directly or indirectly, 75 or more single-family properties from making an unsolicited offer to purchase, as defined, real property that is located in an area affected by a wildfire disaster for which a state of emergency has been proclaimed by the Governor or the President of the United States. The bill would apply this prohibition for 5 years commencing on the date that the state of emergency is proclaimed. The bill would make its provisions severable."}], "other_titles": [{"note": "", "title": "Housing: disaster impacted areas."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1090"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-02-13", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 16.", "date": "2026-02-17", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-02-26", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee with author's amendments. 