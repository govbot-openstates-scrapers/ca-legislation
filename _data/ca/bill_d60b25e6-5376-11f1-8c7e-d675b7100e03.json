{"legislative_session": "20252026", "identifier": "SB1245", "title": "Petroleum : report.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Petroleum", "report"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes the Division of Petroleum Market Oversight in the State Energy Resources Conservation and Development Commission to, among other things, provide independent oversight and analysis of the transportation fuels market for the protection of consumers by identifying market design flaws, market power abuses, and any other manner by which market participants act to harm competition or act contrary to the best interests of the consumers in the state. Existing law requires the division to report its findings and recommendations to improve market performance, at least annually, to the Legislature, the Governor, the commission, the Attorney General, and the California Department of Tax and Fee Administration.\n\nThis bill would make the annual report due on or before July 1 of each year."}], "other_titles": [{"note": "", "title": "Renewable energy resources: electrical transmission and distribution grid."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1245"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}, {"description": 