{"legislative_session": "20252026", "identifier": "AB1910", "title": "Public health: pelvic floor therapy resources.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Publichealth", "pelvicfloortherapyresources"], "abstracts": [{"note": "summary", "abstract": "Existing law finds and declares that prenatal and postpartum care, among other things, are essential services necessary to ensure maternal health. Existing law establishes the State Department of Public Health, and vests the department with certain duties relating to maternal health, including maintaining a program of maternal and child health, as provided.\n\nThis bill would require the department to post information regarding pelvic floor therapy resources to its internet website, as provided."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1910"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 15.", "date": "2026-02-13", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on HEALTH.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on HEALTH.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass and re-refer to Com. on APPR. with recommendation: To Consent Calendar. (Ayes 16. Noes 0.) (March 17). Re-referred to Com. on APPR.", "date": "2026-03-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage", "committee-passage-favorable", "referral-committee"], "related_entities": [{"name": "Com. on APPR.", "entity_type": "organization", "organizat