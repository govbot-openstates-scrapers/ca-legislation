{"legislative_session": "20252026", "identifier": "AB2148", "title": "Elementary and secondary education: public school employees: contractors: natural persons.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Elementaryandsecondaryeducation", "contractors", "naturalpersons", "publicschoolemployees"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes a system of public elementary and secondary education in this state. Under this system, school districts, county offices of education, and charter schools employ personnel to provide instruction to and services for pupils in kindergarten and grades 1 to 12, inclusive, at schoolsites throughout the state.\n\nThis bill would explicitly define, for purposes of the Education Code, both a public school employee and a contractor providing services in a public school to mean a natural person."}], "other_titles": [{"note": "", "title": "Local educational agency employees: public postsecondary education employees: artificial intelligence, automated decision systems, and educational technology: discipline."}, {"note": "", "title": "School personnel."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2148"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 21.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Coms. on ED., HIGHER ED. and P. & C.P.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Coms. on ED., HIGHER ED. and P. & C.P.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with 