{"legislative_session": "20252026", "identifier": "SB1129", "title": "Consumer affairs.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Consumeraffairs"], "abstracts": [{"note": "summary", "abstract": "The State Bar Act establishes the State Bar of California (State Bar) as a public corporation and assigns to the State Bar various duties with respect to the licensing and regulations of attorneys in the state.\n\nThis bill would require the State Bar to create a working group to examine the results of community justice worker models in other states and jurisdictions and the impact of providing services to people who otherwise would not have received legal services. The bill would also require the working group to submit, as specified, a report with findings and recommendations to the Legislature before January 1, 2029."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1129"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-02-17", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 20.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-02-26", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee with author's amendments. Read second time and amended. Re-referred to Com. on RLS.", "date": "2026-03-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["amendment-passage", "committee-passage", "reading-1", "reading-2", "referral-committee"], "