{"legislative_session": "20252026", "identifier": "AB1857", "title": "The Grocery Store Access Act.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["TheGroceryStoreAccessAct"], "abstracts": [{"note": "summary", "abstract": "Existing law makes void and unenforceable any covenant, restriction, or condition contained in any deed, contract, security instrument, or other instrument affecting the transfer or sale of any interest in real property that effectively prohibits or restricts certain land uses, including the installation or use of a solar energy system or construction or use of an accessory dwelling unit or junior accessory dwelling unit on certain lots.\n\nThis bill would make void and unenforceable any covenant, restriction, or condition contained in any deed, contract, security instrument, lease, or other recorded or unrecorded instrument affecting the transfer or sale of any interest in real property that effectively prohibits or restricts the use of that property as a grocery store or supermarket, as defined. The bill would include findings and declarations relating to these provisions."}], "other_titles": [{"note": "", "title": "Conditions of ownership: grocery stores."}], "other_identifiers": [], "actions": [{"description": "Read first time. To print.", "date": "2026-02-11", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 14.", "date": "2026-02-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on JUD.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amen