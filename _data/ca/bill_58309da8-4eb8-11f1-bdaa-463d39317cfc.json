{"legislative_session": "20252026", "identifier": "SCR128", "title": "Relative to High School Voter Education Weeks.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["concurrent resolution"], "subject": ["HighSchoolVoterEducationWeeks"], "abstracts": [{"note": "summary", "abstract": "This measure would declare Monday, April 13, 2026, to Friday, April 24, 2026, inclusive, as High School Voter Education Weeks and would strongly encourage local educational agencies to dedicate at least one of those 2 weeks to educating pupils in grades 9 to 12, inclusive, on the electoral process, as provided. The measure would encourage local educational agencies to provide digital and physical resources necessary to provide this information and would encourage the governing boards or bodies of local educational agencies to contract with third-party nonprofit organizations, as provided, to accomplish this endeavor."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-scr128"}], "actions": [{"description": "Introduced. Referred to Com. on RLS.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Ordered to third reading.", "date": "2026-02-26", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["committee-passage"], "related_entities": []}, {"description": "Read third time and amended.", "date": "2026-04-27", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["amendment-passage", "reading-1", "reading-3"], "related_entities": []}, {"description": "Ordered to second reading.", "date": "2026-04-27", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read second time. Ordered to third reading.", "date