{"legislative_session": "20252026", "identifier": "AB2104", "title": "Sexually violent predators.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Sexuallyviolentpredators"], "abstracts": [{"note": "summary", "abstract": "Existing law provides for the civil commitment of a person who is determined to be a sexually violent predator. Existing law establishes a procedure by which a person committed as a sexually violent predator may petition for conditional release and requires the court, if it makes a specified determination, to place the person on conditional release. \n\nThis bill would require a court presiding over any proceeding held pursuant to the above-described provisions that is open to the public to provide the public with a remote access option that allows members of the public to remotely observe the proceeding."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2104"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 21.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on PUB. S.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on PUB. S.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on PUB. S. Read second time and amended.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred 