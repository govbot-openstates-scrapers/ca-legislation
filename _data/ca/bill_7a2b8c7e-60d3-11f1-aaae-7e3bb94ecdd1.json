{"legislative_session": "20252026", "identifier": "AB2337", "title": "Peace officers: theft.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Peaceofficers", "theft"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes the Commission on Peace Officer Standards and Training (POST) to set minimum standards for the recruitment and training of peace officers and to develop training courses and curriculum. Existing law authorizes POST to suspend or revoke the certification of a peace officer if the peace officer has engaged in any serious misconduct, as specified. Existing law requires POST to adopt by regulation a definition of \"serious misconduct\" that serves as the criteria to be considered for ineligibility for, or revocation of, certification, as provided.\n\nThis bill would additionally authorize POST to suspend or revoke the certification of a peace officer who commits specified theft under color of authority."}], "other_titles": [{"note": "", "title": "Theft."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2337"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on PUB. S.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on PUB. S.", "entity_type": "organization", "organization_id": null}]}, {"description": "In committee: Set, first hearing. Hearing canceled at the request of author.", "date": "2026-04-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": 