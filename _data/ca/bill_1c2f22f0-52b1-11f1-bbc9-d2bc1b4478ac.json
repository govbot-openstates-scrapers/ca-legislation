{"legislative_session": "20252026", "identifier": "SB1005", "title": "Local agency: payment: rounding amount.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Localagency", "payment", "roundingamount"], "abstracts": [{"note": "summary", "abstract": "Existing law requires a public agency to accept specified methods of payment for designated obligations.\n\nThis bill would authorize a local agency to round the amount of any payment made wholly or partly in cash to the local agency, or any refund or other amount tendered wholly or partly in cash by the local agency, to the nearest $0.05. The bill would apply to a local agency only if the governing body of the local agency adopts, by majority vote, a resolution to make its provisions applicable to the local agency. The bill would define terms for its purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1005"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-02-09", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 12.", "date": "2026-02-10", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on L. GOV.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on L. GOV.", "entity_type": "organization", "organization_id": null}]}, {"description": "Set for hearing March 18.", "date": "2026-03-05", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "From committee: Do pass. Ordered to consent calendar. (Ayes 7. Noes 0. Page 3601.) (March 18).", "date": "2026-03-18", "organiz