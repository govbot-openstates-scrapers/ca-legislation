{"legislative_session": "20252026", "identifier": "AB1948", "title": "Firearms: concealed carry licenses.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Firearms", "concealedcarrylicenses"], "abstracts": [{"note": "summary", "abstract": "Existing law prohibits a person from carrying a concealed firearm or carrying a loaded firearm in public. Existing law requires a licensing authority to issue or renew a license to carry a firearm capable of being concealed if specified conditions are met, including, among others, that the applicant is not a disqualified person for the license, as specified, and the applicant has completed a specified course of training. Existing law makes a new or renewal license that is issued to be valid for a period of time not to exceed 2 years from the date of the license, except as otherwise provided.\n\nThis bill would extend the duration of those licenses to 3 years from the date of the license. The bill would make conforming changes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1948"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-13", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 16.", "date": "2026-02-14", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on PUB. S.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on PUB. S.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Amend, and do pass as amended. To Consent Calendar. (Ayes 9. Noes 0.) (March 17).", "date": "2026-03-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amen