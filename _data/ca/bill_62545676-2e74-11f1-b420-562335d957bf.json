{"legislative_session": "20252026", "identifier": "SB1214", "title": "State Butterfly.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["StateButterfly"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes various official emblems of the state, including establishing the California dog-face butterfly (zerene eurydice) as the official State Insect.\n\nThis bill would establish the western monarch butterfly (danaus plexippus) as the official State Butterfly. The bill would make related findings and declarations."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1214"}], "actions": [{"description": "Introduced. Read first time. To Com. on RLS. for assignment. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on G.O.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on G.O.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee with author's amendments. Read second time and amended. Re-referred to Com. on G.O.", "date": "2026-03-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["amendment-passage", "committee-passage", "reading-1", "reading-2", "referral-committee"], "related_entities": [{"name": "Com. on G.O.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Ochoa Bogh", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Ochoa Bogh\"}", "organization_id": null}], "related_