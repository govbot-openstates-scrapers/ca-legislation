{"legislative_session": "20252026", "identifier": "AB1662", "title": "Driving record: points: misdemeanor diversion.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Drivingrecord", "misdemeanordiversion", "points"], "abstracts": [{"note": "summary", "abstract": "Existing law imposes various violation points against a driver's record for purposes of the suspension or revocation of the privilege to drive by the Department of Motor Vehicles (DMV) if a driver is convicted of a number of specified violations, including a conviction of driving under the influence or vehicular manslaughter. Existing law authorizes a judge in the superior court in which a misdemeanor is being prosecuted to offer diversion to a defendant, and requires the judge, at the end of the diversion period and if the defendant has complied with the imposed terms and conditions, to dismiss the action against the defendant.\n\nThis bill would require a court that has, upon the above-described diversion, dismissed a misdemeanor case that includes a violation that is required to be assessed points to transmit that information to the DMV, and would require the DMV to assess the applicable points on the driver's record."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1662"}], "actions": [{"description": "Read first time. To print.", "date": "2026-01-29", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 1.", "date": "2026-01-30", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Coms. on PUB. S. and TRANS.", "date": "2026-02-17", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Coms. on PUB. S. and TRANS.", "entity_type": "organization", "