{"legislative_session": "20252026", "identifier": "AB2155", "title": "Arbitration: validity of agreements to arbitrate.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Arbitration", "validityofagreementstoarbitrate"], "abstracts": [{"note": "summary", "abstract": "Existing law provides that written agreements to submit controversies to arbitration are valid and enforceable. Existing federal law, the Federal Arbitration Act, also deems arbitration agreements valid, irrevocable, and enforceable, except for certain specified types of agreements, such as agreements to arbitrate claims of sexual harassment.\n\nThis bill would make agreements to submit to arbitration unenforceable where the agreement would not be enforceable under the Federal Arbitration Act."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2155"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 21.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on JUD.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass. To Consent Calendar. (Ayes 12. Noes 0.) (April 14).", "date": "2026-04-15", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage", "committee-passage-favorable"], "related_entities": []}, {"description": "Read second time. Ordered to Consent Calendar.", "date": "2026-04-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1", "reading-2"], "related_entities": []}], "sponsorships": [{"name": "Aguiar-Curry", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Aguiar-Curry\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "AB2155", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB2155", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "02/18/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB2155&version=20250AB215599INT", "media_type": "application/pdf"}], "date": "2026-02-18", "classification": ""}], "documents": [{"note": "04/11/26- Assembly Judiciary", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billAnalysisClient.xhtml?bill_id=202520260AB2155&analysisId=395578&analyzingOffice=Assembly+Judiciary", "media_type": "application/pdf"}], "date": "2026-04-11", "classification": "analysis"}], "citations": [], "sources": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB2155", "note": ""}], "extras": {"impact_clause": "An act to amend Section 1281 of the Code of Civil Procedure, relating to arbitration.", "tags": []}, "jurisdiction": {"id": "ocd-jurisdiction/country:us/state:ca/government", "name": "California", "classification": "state", "division_id": "ocd-division/country:us/state:ca"}, "scraped_at": "2026-04-17T09:33:55+00:00", "_id": "8db8a15a-3a40-11f1-bc46-ee9b108c6caa"}