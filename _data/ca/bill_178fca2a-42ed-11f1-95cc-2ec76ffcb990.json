{"legislative_session": "20252026", "identifier": "AB2173", "title": "Gambling Control Act.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["GamblingControlAct"], "abstracts": [{"note": "summary", "abstract": "Existing law, the Gambling Control Act, establishes the California Gambling Control Commission, which is responsible for licensing and regulating various gambling activities and establishments. Existing law requires the commission to maintain a public record of every vote at its principal office.\n\nThis bill would additionally require the commission to post a public record of every vote on the commission's internet website no later than the close of business on the 2nd business day after the meeting at which the vote was taken."}], "other_titles": [{"note": "", "title": "Tribal gaming: compact ratification."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2173"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on G.O.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on G.O.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on G.O. Read second time and amended.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred to Com. on G.O.", "date": "2026-03-23"