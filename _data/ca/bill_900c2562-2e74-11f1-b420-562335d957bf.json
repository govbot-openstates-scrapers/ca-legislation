{"legislative_session": "20252026", "identifier": "AB1912", "title": "Deer: archery season: concealed firearms.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Deer", "archeryseason", "concealedfirearms"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes an archery season for the taking of deer with bow and arrow. Existing law generally prohibits a person taking or attempting to take deer during that archery season from carrying, or having under their immediate control, a firearm of any kind, except for an active or honorably retired peace officer, as specified.\n\nThis bill would repeal that prohibition."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1912"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 15.", "date": "2026-02-13", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Coms. on W., P., & W. and PUB. S.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Coms. on W., P., & W. and PUB. S.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Amend, and do pass as amended and re-refer to Com. on PUB. S. (Ayes 12. Noes 0.) (March 24).", "date": "2026-03-24", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "committee-passage", "referral-committee"], "related_entities": []}, {"description": "Read second time and amended.", "date": "2026-03-25", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-passage", "reading-1", "re