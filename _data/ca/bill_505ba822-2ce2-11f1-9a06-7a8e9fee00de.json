{"legislative_session": "20252026", "identifier": "AB2521", "title": "Sustainable groundwater management.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Sustainablegroundwatermanagement"], "abstracts": [{"note": "summary", "abstract": "Existing law, the Sustainable Groundwater Management Act, requires all groundwater basins designated as high- or medium-priority basins by the Department of Water Resources to be managed under a groundwater sustainability plan or coordinated groundwater sustainability plans, except as specified. Existing law defines various terms for purposes of the act.\n\nThis bill would add the defined term \"best available science\" for purposes of the act."}], "other_titles": [{"note": "", "title": "San Francisco Bay Conservation and Development Commission."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2521"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on W., P., & W.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on W., P., & W.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on W., P., & W. Read second time and amended.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred to Com. on W., P., & W.", "date": "2026-03-23", "o