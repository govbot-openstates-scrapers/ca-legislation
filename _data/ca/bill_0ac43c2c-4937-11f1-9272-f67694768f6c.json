{"legislative_session": "20252026", "identifier": "SB1388", "title": "Local agencies: improvement and maintenance of natural habitat.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Localagencies", "improvementandmaintenanceofnaturalhabitat"], "abstracts": [{"note": "summary", "abstract": "Existing law authorizes a local agency to, as specified, establish a district to provide for the improvement or maintenance of natural habitat. Existing law authorizes the local agency to perform those functions or contract with the state, another local agency, or a special district to perform those functions, as specified.\n\nThis bill would additionally authorize a local agency to contract with a joint powers authority to perform the above-described functions."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-sb1388"}], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Referred to Com. on L. GOV.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on L. GOV.", "entity_type": "organization", "organization_id": null}]}, {"description": "Set for hearing April 29.", "date": "2026-04-09", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "From committee: Do pass. Ordered to consent c