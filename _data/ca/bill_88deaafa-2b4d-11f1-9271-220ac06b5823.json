{"legislative_session": "20252026", "identifier": "AB1949", "title": "Medi-Cal: acupuncture treatments.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Medi-Cal", "acupuncturetreatments"], "abstracts": [{"note": "summary", "abstract": "Existing law establishes the Medi-Cal program, which is administered by the State Department of Health Care Services, under which qualified low-income individuals receive health care services, including pharmacy services and drugs. The Medi-Cal program is, in part, governed and funded by federal Medicaid Program provisions. Existing law sets forth a schedule of benefits covered under the Medi-Cal program, including acupuncture, but only to the extent federal matching funds are provided for acupuncture.\n\nThis bill would require the Medi-Cal program to cover up to 24 acupuncture visits per beneficiary per calendar year and would state that the benefit is not subject to utilization controls, except as specified."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1949"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-13", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 16.", "date": "2026-02-14", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on HEALTH.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on HEALTH.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on HEALTH. Read second time and amended.", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred to Com. on HEALTH.", "date": "2026-03-17", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on HEALTH.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Lee", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Lee\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "AB1949", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB1949", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "02/13/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB1949&version=20250AB194999INT", "media_type": "application/pdf"}], "date": "2026-02-13", "classification": ""}, {"note": "03/16/26 - Amended Assembly", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB1949&version=20250AB194998AMD", "media_type": "application/pdf"}], "date": "2026-03-16", "classification": ""}], "documents": [], "citations": [], "sources": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB1949", "note": ""}], "extras": {"impact_clause": "An act to amend Section 14132 of, and to add Section 14133.03 to, the Welfare and Institutions Code, relating to Medi-Cal.", "tags": ["fiscal committee"]}, "jurisdiction": {"id": "ocd-jurisdiction/country:us/state:ca/government", "name": "California", "classification": "state", "division_id": "ocd-division/country:us/state:ca"}, "scraped_at": "2026-03-29T08:59:03+00:00", "_id": "88deaafa-2b4d-11f1-9271-220ac06b5823"}