{"legislative_session": "20252026", "identifier": "SB1377", "title": "Health facilities.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Healthfacilities"], "abstracts": [{"note": "summary", "abstract": "Existing law requires a licensed general acute care hospital or acute psychiatric hospital to adopt policies and procedures regarding the responsibility for ensuring proper methods of repackaging and labeling of bulk cleaning agents, solvents, chemicals, and nondrug hazardous substances used throughout the hospital and does not require these health facilities to consult a pharmacist regarding the repackaging and labeling of these substances, except as specified.\n\nThis bill would make technical, nonsubstantive changes to these provisions."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Jones", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Jones\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "SB1377", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNa