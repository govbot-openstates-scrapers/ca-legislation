{"legislative_session": "20252026", "identifier": "AB1875", "title": "Dissolution of marriage.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Dissolutionofmarriage"], "abstracts": [{"note": "summary", "abstract": "Existing law governs the dissolution of marriage and legal separation. Existing law prohibits a judgment of dissolution of marriage from being made final until 6 months have expired from the date of service of a copy of the summons and petition or the date of appearance of the respondent, whichever occurs first. Existing law authorizes a court to extend the 6-month period for good cause shown. Existing law also requires a court to enter a judgment dissolving a marriage when 6 months have expired from the date of the filing of a joint petition for summary dissolution, unless a revocation has been filed.\n\nThis bill would additionally authorize the court to reduce or waive the 6-month period described above for good cause shown."}], "other_titles": [{"note": "", "title": "Confidential marriage."}], "other_identifiers": [], "actions": [{"description": "Read first time. To print.", "date": "2026-02-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 15.", "date": "2026-02-13", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on JUD.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on JUD. Read second time and amended.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred to Com. on JUD.", "date": "2026-03-03", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Hart", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Hart\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "AB1875", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB1875", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "02/12/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB1875&version=20250AB187599INT", "media_type": "application/pdf"}], "date": "2026-02-12", "classification": ""}, {"note": "03/02/26 - Amended Assembly", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB1875&version=20250AB187598AMD", "media_type": "application/pdf"}], "date": "2026-03-02", "classification": ""}], "documents": [], "citations": [], "sources": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB1875", "note": ""}], "extras": {"impact_clause": "An act to amend Sections 2339 and 2403 of the Family Code, relating to marriage.", "tags": []}, "jurisdiction": {"id": "ocd-jurisdiction/country:us/state:ca/government", "name": "California", "classification": "state", "division_id": "ocd-division/country:us/state:ca"}, "scraped_at": "2026-03-04T08:55:51+00:00", "_id": "f20d8140-17a7-11f1-bbcd-5e8cf97b3b30"}