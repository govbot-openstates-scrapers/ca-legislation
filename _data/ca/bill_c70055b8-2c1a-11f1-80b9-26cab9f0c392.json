{"legislative_session": "20252026", "identifier": "AB1741", "title": "Sexual battery.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Sexualbattery"], "abstracts": [{"note": "summary", "abstract": "Existing law defines sexual battery as the touching of any intimate part of another person, if the touching is against the will of the person touched and for the purpose of sexual arousal, gratification, or abuse. A violation of this provision is punishable as a misdemeanor.\n\nThis bill would make a violation of the above provision punishable as a misdemeanor or a felony if the person entered an inhabited dwelling house or trailer coach, as defined, or the inhabited portion of any other building without consent. By creating a new crime, this bill would impose a state-mandated local program. The bill would make other technical, conforming changes.\n\nThe California Constitution requires the state to reimburse local agencies and school districts for certain costs mandated by the state. Statutory provisions establish procedures for making that reimbursement.\n\nThis bill would provide that no reimbursement is required by this act for a specified reason."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1741"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-05", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 8.", "date": "2026-02-06", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on PUB. S.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on PUB. S.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Amend, and do pass as amended and re-refer to Com. on APPR. (Ayes 9. Noes 0.) (March 10).", "date": "2026-03-10", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "committee-passage", "referral-committee"], "related_entities": []}, {"description": "Read second time and amended.", "date": "2026-03-11", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred to Com. on APPR.", "date": "2026-03-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on APPR.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Pacheco", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Pacheco\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "AB1741", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB1741", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "02/05/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB1741&version=20250AB174199INT", "media_type": "application/pdf"}], "date": "2026-02-05", "classification": ""}, {"note": "03/11/26 - Amended Assembly", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB1741&version=20250AB174198AMD", "media_type": "application/pdf"}], "date": "2026-03-11", "classification": ""}], "documents": [{"note": "03/09/26- Assembly Public Safety", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billAnalysisClient.xhtml?bill_id=202520260AB1741&analysisId=394249&analyzingOffice=Assembly+Public+Safety", "media_type": "application/pdf"}], "date": "2026-03-09", "classification": "analysis"}], "cit