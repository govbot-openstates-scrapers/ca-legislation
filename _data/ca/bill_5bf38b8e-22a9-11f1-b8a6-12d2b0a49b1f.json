{"legislative_session": "20252026", "identifier": "AB1597", "title": "Notary public: service fees.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Notarypublic", "servicefees"], "abstracts": [{"note": "summary", "abstract": "Existing law authorizes the Secretary of State to appoint and commission notaries public in the number that the secretary deems necessary for the public convenience. Existing law prohibits fees charged by a notary public for certain services, including taking an acknowledgment or proof of a deed, from exceeding specified amounts.\n\nThis bill would increase those amounts, as specified, and make findings and declarations related to these provisions."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1597"}], "actions": [{"description": "Read first time. To print.", "date": "2026-01-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee February 16.", "date": "2026-01-17", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on JUD.", "date": "2026-02-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass. To Consent Calendar. (Ayes 12. Noes 0.) (March 10).", "date": "2026-03-10", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage", "committee-passage-favorable"], "related_entities": []}, {"description": "Read second time. Ordered to Consent Calendar.", "date": "2026-03-11", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1", "reading-2"], "related_entities": []}, {"description": "Read third time. P