{"legislative_session": "20252026", "identifier": "AB1673", "title": "County fish and wildlife propagation fund: expenditure.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Countyfishandwildlifepropagationfund", "expenditure"], "abstracts": [{"note": "summary", "abstract": "Existing law requires certain fines and penalties paid to and retained in a county treasury to be deposited in a county fish and wildlife propagation fund and expended for the protection, conservation, propagation, and preservation of fish and wildlife, as specified. Existing law authorizes expenditures from a county fish and wildlife propagation fund for purposes relating to fish and wildlife, including, among other things, costs incurred by a district attorney or city attorney in investigating and prosecuting civil and criminal actions relating to fish and wildlife.\n\nThis bill would additionally authorize expenditures from a county fish and wildlife propagation fund for costs relating to wildlife coexistence programs to prevent human-wildlife conflict."}], "other_titles": [{"note": "", "title": "Fish and wildlife: dates."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1673"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 5.", "date": "2026-02-03", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on W., P., & W.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on W., P., & W.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com.