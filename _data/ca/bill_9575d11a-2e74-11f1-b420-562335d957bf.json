{"legislative_session": "20252026", "identifier": "AB2322", "title": "Appropriation of water: notice of hearing.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Appropriationofwater", "noticeofhearing"], "abstracts": [{"note": "summary", "abstract": "Existing law requires the State Water Resources Control Board to act upon all applications for a permit to appropriate water. Existing law establishes various requirements for a notice regarding an application received by the board, including, among other requirements, that notice be given by mail not less than 20 days before the date of a hearing for an unprotested application.\n\nThis bill would require notice to be given by mail not less than 15 days before the date of a hearing for an unprotested application."}], "other_titles": [{"note": "", "title": "State Water Resources Control Board."}], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2322"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on W., P., & W.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on W., P., & W.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on W., P., & W. Read second time and amended.", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "