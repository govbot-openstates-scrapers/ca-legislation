{"legislative_session": "20252026", "identifier": "AB2290", "title": "Civil discovery: oral depositions: transcriptions.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Civildiscovery", "oraldepositions", "transcriptions"], "abstracts": [{"note": "summary", "abstract": "The Civil Discovery Act authorizes a party to obtain discovery by taking the oral deposition of any person. Oral depositions must be conducted under the supervision of a deposition officer, as specified, and, unless otherwise agreed or ordered, the testimony must be taken stenographically and then transcribed. The act provides procedures for the deponent to read, correct, approve, and sign the original deposition transcript and requires the deposition officer to certify and promptly transmit the transcript to the attorney of the party who noticed the deposition in a securely sealed envelope or package.\n\nThis bill would permit the deposition officer to instead transmit a certified deposition transcript to the attorney of the party who noticed the deposition via secure electronic means, when requested by that attorney."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "Read first time. To print.", "date": "2026-02-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 22.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on JUD.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee chair, with author's amendments: Amend, and re-refer to Com. on JUD. Read second time and amended.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["amendment-introduction", "amendment-passage", "reading-1", "reading-2"], "related_entities": []}, {"description": "Re-referred to Com. on JUD.", "date": "2026-03-03", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Lackey", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Lackey\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "AB2290", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB2290", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "02/19/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB2290&version=20250AB229099INT", "media_type": "application/pdf"}], "date": "2026-02-19", "classification": ""}, {"note": "03/02/26 - Amended Assembly", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB2290&version=20250AB229098AMD", "media_type": "application/pdf"}], "date": "2026-03-02", "classification": ""}], "documents": [], "citations": [], "sources": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB2290", "note": ""}], "extras": {"impact_clause": "An act to amend Section 2025.550 of the Code of Civil Procedure, relating to civil actions.", "tags": []}, "jurisdiction": {"id": "ocd-jurisdiction/country:us/state:ca/government", "name": "California", "classification": "state", "division_id": "ocd-division/country:us/state:ca"}, "scraped_at": "2026-03-07T08:44:35+00:00", "_id": "de50340c-1a01-11f1-bfb6-3af87c0d1742"}