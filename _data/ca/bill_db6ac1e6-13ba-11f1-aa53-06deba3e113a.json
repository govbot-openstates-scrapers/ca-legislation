{"legislative_session": "20252026", "identifier": "SB1406", "title": "Public Utilities Commission: contracting: audits.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["PublicUtilitiesCommission", "audits", "contracting"], "abstracts": [{"note": "summary", "abstract": "Existing law vests the Public Utilities Commission with broad regulatory jurisdiction and authority over public utilities, including common carriers, electrical corporations, gas corporations, telephone corporations, and water corporations. Existing law requires the commission to make available on its internet website audits of the commission's contracting practices conducted by the Department of General Services.\n\nThis bill would make nonsubstantive changes to that requirement."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}], "sponsorships": [{"name": "McNerney", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"McNerney\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "SB1406", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260SB1406", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "02/20/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260SB1406&version=20250SB140699