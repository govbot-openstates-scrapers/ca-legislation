{"legislative_session": "20252026", "identifier": "ACR220", "title": "Relative to Hepatitis B Awareness Month.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["concurrent resolution"], "subject": ["HepatitisBAwarenessMonth"], "abstracts": [{"note": "summary", "abstract": "This measure, in order to support ongoing public education and to encourage vaccination, screening, and linkage to care, would declare June 2026 as Hepatitis B Awareness Month in California in alignment with national and global awareness activities, and encourage state agencies, local health jurisdictions, community-based organizations, health care providers, and other stakeholders to observe this month with appropriate educational and outreach activities focused on hepatitis B prevention, testing, treatment, and health equity."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-acr220"}], "actions": [{"description": "Introduced. To print.", "date": "2026-06-03", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer.", "date": "2026-06-04", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}], "sponsorships": [{"name": "Nguyen", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Nguyen\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "ACR220", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260ACR220", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "06/03/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260ACR220&version=20250ACR22099INT", "media_type": "application/pdf"}], "date": "2026-06-03", "classification": ""}], "documents": [], "citations": [], "sources": [{"url": "http://leginfo.legislature.ca.