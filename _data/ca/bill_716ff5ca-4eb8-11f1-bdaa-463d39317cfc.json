{"legislative_session": "20252026", "identifier": "AB1916", "title": "Courts: court interpreters.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Courts", "courtinterpreters"], "abstracts": [{"note": "summary", "abstract": "The Trial Court Interpreter Employment and Labor Relations Act (the act) establishes procedures governing the employment and compensation of certified and registered trial court interpreters and court interpreters pro tempore employed by the courts. Under existing law, these provisions do not apply to sign language interpreters.\n\nThis bill would make the provisions of the act applicable to sign language interpreters."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab1916"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 15.", "date": "2026-02-13", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on JUD.", "date": "2026-03-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on JUD.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass and re-refer to Com. on APPR. (Ayes 11. Noes 1.) (March 17). Re-referred to Com. on APPR.", "date": "2026-03-17", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage", "committee-passage-favorable", "referral-committee"], "related_entities": [{"name": "Com. on APPR.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass. (Ayes 12. Noes 0.) (April 22).", "date": "2026-04-22", "organization_id": "~{\"classification\": \"lo