{"legislative_session": "20252026", "identifier": "AB2593", "title": "Corrections: treatment of prisoners.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Corrections", "treatmentofprisoners"], "abstracts": [{"note": "summary", "abstract": "Existing law prohibits the Department of Corrections Rehabilitation from allowing any lack of care that would injure or impair the health of an incarcerated person. Existing law prohibits the department from modifying or canceling the medical treatment of an incarcerated person if a physician certifies that the medical treatment is required to prevent certain violations of law or to prevent serious and imminent harm to the health of an incarcerated person, as specified.\n\nThis bill would prohibit a supervisor, administrator, or employee of the department from interfering with or refusing to implement prescribed health care, as specified, that results in substantial emotional distress or serious bodily injury, as defined."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ca-20252026-ab2593"}], "actions": [{"description": "Read first time. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "From printer. May be heard in committee March 23.", "date": "2026-02-21", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to Com. on PUB. S.", "date": "2026-03-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on PUB. S.", "entity_type": "organization", "organization_id": null}]}, {"description": "From committee: Do pass and re-refer to Com. on APPR. (Ayes 8. Noes 0.) (March 24). Re-referred to Com. on APPR.", "date": "2026-03-25", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage", "committee-passage-favorable", "referral-committee"], "related_entities": [{"name": "Com. on APPR.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Elhawary", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Elhawary\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "AB2593", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB2593", "media_type": "text/html"}], "date": "", "classification": ""}, {"note": "02/20/26 - Introduced", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billPdf.xhtml?bill_id=202520260AB2593&version=20250AB259399INT", "media_type": "application/pdf"}], "date": "2026-02-20", "classification": ""}], "documents": [{"note": "03/23/26- Assembly Public Safety", "links": [{"url": "https://leginfo.legislature.ca.gov/faces/billAnalysisClient.xhtml?bill_id=202520260AB2593&analysisId=394601&analyzingOffice=Assembly+Public+Safety", "media_type": "application/pdf"}], "date": "2026-03-23", "classification": "analysis"}], "citations": [], "sources": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260AB2593", "note": ""}], "extras": {"impact_clause": "An act to add Section 2654 to the Penal Code, relating to corrections.", "tags": ["fiscal committee"]}, "jurisdiction": {"id": "ocd-jurisdiction/country:us/state:ca/government", "name": "California", "classification": "state", "division_id": "ocd-division/country:us/state:ca"}, "scraped_at": "2026-04-13T10:08:42+00:00", "_id": "bfc6b5a6-3720-11f1-88fb-62e5c3a9f2f6"}