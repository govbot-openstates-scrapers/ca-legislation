{"legislative_session": "20252026", "identifier": "SB1280", "title": "Health care service plan requirements.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Healthcareserviceplanrequirements"], "abstracts": [{"note": "summary", "abstract": "Existing law, the Knox-Keene Health Care Service Plan Act of 1975, provides for the licensure and regulation of health care service plans by the Department of Managed Health Care. Existing law requires a health care service plan to meet specified requirements, and requires a health care service plan contract to provide to subscribers and enrollees specified basic health care services.\n\nThis bill would make technical, nonsubstantive changes to those provisions."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "Introduced. To Com. on RLS. for assignment. To print.", "date": "2026-02-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "From printer. May be acted upon on or after March 23.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Read first time.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Referred to Com. on RLS.", "date": "2026-03-04", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Com. on RLS.", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Valladares", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Valladares\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "SB1280", "links": [{"url": "http://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202520260S